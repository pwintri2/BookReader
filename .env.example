BOOKREADER_API_HOST=127.0.0.1
BOOKREADER_API_PORT=1433
BOOKREADER_OUTPUT_DIR=out/bookreader

# Optional local/server TTS with Piper. By default the API checks
# .venv_piper/bin/piper and out/bookreader/voices.
# BOOKREADER_PIPER_BIN=/home/pwintri2/BookReader/.venv_piper/bin/piper
# BOOKREADER_PIPER_VOICES_DIR=/home/pwintri2/BookReader/out/bookreader/voices
# BOOKREADER_PIPER_MODEL=nl_NL-ronnie-medium
# BOOKREADER_TTS_MAX_CHARS=24000

# Optional ComfyUI bridge.
BOOKREADER_COMFY_URL=http://127.0.0.1:8188
# Defaults to server/comfy/bookreader-workflow-api.json.
# BOOKREADER_COMFY_WORKFLOW=/opt/bookreader/comfy/bookreader-workflow-api.json

# Optional DeepSeek/Ollama context analyzer.
BOOKREADER_OLLAMA_URL=http://127.0.0.1:11434
BOOKREADER_CONTEXT_MODEL=deepseek-r1:1.5b
BOOKREADER_DEEP_CONTEXT_MODEL=deepseek-r1:7b
BOOKREADER_CONTEXT_TIMEOUT_MS=35000
BOOKREADER_DEEP_CONTEXT_TIMEOUT_MS=120000
BOOKREADER_STORY_MODEL=deepseek-llm:7b-chat
BOOKREADER_DEEP_STORY_MODEL=deepseek-llm:7b-chat
BOOKREADER_STORY_TIMEOUT_MS=180000
BOOKREADER_DEEP_STORY_TIMEOUT_MS=360000

# Optional cloud DeepSeek API for stronger context/story generation.
# Keep this key server-side only; never expose it as a VITE_* variable.
# BOOKREADER_DEEPSEEK_API_KEY=sk-...
BOOKREADER_DEEPSEEK_API_BASE_URL=https://api.deepseek.com
BOOKREADER_DEEPSEEK_API_CONTEXT_MODEL=deepseek-v4-flash
BOOKREADER_DEEPSEEK_API_STORY_MODEL=deepseek-v4-flash

# For VPS deployments, restrict this to the public BookReader origin.
BOOKREADER_CORS_ORIGIN=*
