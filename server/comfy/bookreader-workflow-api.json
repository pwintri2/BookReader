{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly-fp16.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Positive Prompt"
    },
    "inputs": {
      "text": "storybook illustration of a quiet reading scene",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "Negative Prompt"
    },
    "inputs": {
      "text": "low quality, blurry, readable text, watermark, logo",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 768,
      "height": 1024,
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "seed": 0,
      "steps": 24,
      "cfg": 7,
      "sampler_name": "euler",
      "scheduler": "normal",
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "denoise": 1
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "BookReader"
    }
  }
}
